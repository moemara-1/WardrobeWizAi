{
  "expo": {
    "name": "WardrobeWizAi",
    "slug": "wardrobewizai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wardrobewizai",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0E",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wardrobewizai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "WardrobeWizAi needs camera access to photograph your clothing items for analysis.",
        "NSPhotoLibraryUsageDescription": "WardrobeWizAi needs photo library access to import your clothing photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0B0E"
      },
      "package": "com.wardrobewizai.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow WardrobeWizAi to access your camera to photograph clothing items."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow WardrobeWizAi to access your photos to import clothing images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}