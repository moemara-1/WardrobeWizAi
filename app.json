{
  "expo": {
    "name": "WardrobeWizAi",
    "slug": "wardrobewizai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0E"
    },
    "scheme": "wardrobewizai",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0B0B0E",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wardrobewizai.app",
      "buildNumber": "6",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "WardrobeWizAi needs camera access to photograph your clothing items for analysis.",
        "NSPhotoLibraryUsageDescription": "WardrobeWizAi needs photo library access to import your clothing photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0B0E"
      },
      "package": "com.wardrobewizai.app",
      "versionCode": 6,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow WardrobeWizAi to access your camera to photograph clothing items."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow WardrobeWizAi to access your photos to import clothing images."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "updates": {
      "url": "https://u.expo.dev/be04d0ab-fc16-4fd0-816f-506f3f2bf5a3"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "be04d0ab-fc16-4fd0-816f-506f3f2bf5a3"
      }
    }
  }
}