# ─── Supabase (REQUIRED) ───
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Sentry (optional — crash reporting) ───
# EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ─── OpenWeatherMap (client-side) ───
EXPO_PUBLIC_OPENWEATHERMAP_KEY=your-openweathermap-api-key

# ─── Edge Function Secrets (set via: supabase secrets set KEY=value) ───
# These are NOT used client-side — they live in Supabase Edge Functions only.
# DEEPINFRA_KEY=your-deepinfra-api-key
# REMOVEBG_API_KEY=your-removebg-api-key
# GOOGLE_VISION_KEY=your-google-vision-api-key
# REPLICATE_API_TOKEN=your-replicate-api-token
