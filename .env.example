# ─── Supabase (REQUIRED) ───
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Edge Function Secrets (set via: supabase secrets set KEY=value) ───
# These are NOT used client-side — they live in Supabase Edge Functions only.
# DEEPINFRA_KEY=your-deepinfra-api-key
# REMOVEBG_API_KEY=your-removebg-api-key
